# Copy this file to .env and fill in real values. .env is gitignored.

# Datawrapper API token — used by the blog-charts skill.
# Generate at https://app.datawrapper.de/account/api-tokens
# Required scopes: chart:read, chart:write, folder:read, folder:write,
#                  theme:read, user:read.
DATAWRAPPER_API_TOKEN=
